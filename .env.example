# Copy this file to .env.local and fill in values from your Firebase project
# settings (Project settings > General > Your apps > SDK setup and configuration).
# Without these, the app runs fully offline with cloud sync disabled.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
